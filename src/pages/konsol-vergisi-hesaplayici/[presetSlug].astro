---
import type { Preset, Brand } from "@/domains/konsol-vergisi-hesaplayici/types.js";
import AppLayout from "@/layouts/app-layout.astro";
import PageHeader from "@/components/common/page-header.vue";
import Container from "@/components/common/container.vue";
import Breadcrumbs from "@/components/common/breadcrumbs.vue";
import Heading1 from "@/components/common/heading-1.vue";
import KonsolVergisiHesaplayiciPreset
    from "@/domains/konsol-vergisi-hesaplayici/components/konsol-vergisi-hesaplayici-preset.vue";
import Heading2 from "@/components/common/heading-2.vue";
import CalculatorPresetCarousel from "@/components/calculator-preset-carousel.astro";
import { Image } from "astro:assets";

import { getPresetsForAllBrands, getBrandById } from "@/domains/konsol-vergisi-hesaplayici/db.js";
import {
    KonsolVergisiHesaplayiciPageDef,
    KonsolVergisiHesaplayiciPresetSlugPageDef
} from "@/domains/konsol-vergisi-hesaplayici/page-def.js";
import {
    mapPresetsForCalculatorPresetCarouselComponent
} from "@/domains/konsol-vergisi-hesaplayici/utils/map-presets-for-calculator-preset-carousel-component.js";
import { calculateResults } from "@/domains/konsol-vergisi-hesaplayici/utils/calculate-results.js";
import { DEFAULT_PRESET_FORM } from "@/domains/konsol-vergisi-hesaplayici/config.js";
import { getThumbByFileName } from "@/utils/thumb-loader.js";

export const getStaticPaths = (): object => {
    return getPresetsForAllBrands().map(_preset => ({
        params: {
            presetSlug: _preset.slug
        },
        props: {
            preset: _preset,
            brand: getBrandById(_preset.brandId)
        }
    }));
};

type Props = {
    preset: Preset;
    brand: Brand;
};
const { preset, brand } = Astro.props;

const konsolVergisiHesaplayiciPage = KonsolVergisiHesaplayiciPageDef();
const konsolVergisiHesaplayiciPresetSlugPage = KonsolVergisiHesaplayiciPresetSlugPageDef({ preset, brand });

const EXCHANGE_RATES = getExchangeRates();
const presets = getPresetsForAllBrands();
const presetsForCalculatorPresetCarousel = mapPresetsForCalculatorPresetCarouselComponent(
    presets.filter(_preset => _preset.brandId === preset.brandId && _preset.slug !== preset.slug) // Show same brands and hide current
);

const calculateServerSide = () => {
    const optionIndex = 0;
    // oxlint-disable-next-line typescript/no-non-null-assertion
    const option = preset.options[optionIndex]!;

    const form = {
        ...DEFAULT_PRESET_FORM,
        ...option.form
    };

    const {
        results,
        resultList,
        screenshotData,
        chartData
    } = calculateResults({
        form,
        exchangeRates: EXCHANGE_RATES
    });

    return {
        form,
        results,
        resultList,
        screenshotData,
        chartData
    };
};

const initial = calculateServerSide();
const thumb = getThumbByFileName(preset.thumb);
---

<AppLayout page={konsolVergisiHesaplayiciPresetSlugPage}>
    <PageHeader>
        <Container>
            <Breadcrumbs
                items={konsolVergisiHesaplayiciPresetSlugPage.breadcrumbs}
                client:load />
        </Container>
    </PageHeader>

    <section class="preset-hero">
        <Container>
            <Image
                src={thumb.metadata}
                alt={`${brand.title} ${preset.title}`}
                loading="eager"
                height="96"
                densities={[1, 2]}
                decoding="async"
                aria-hidden="true"
                draggable="false"
                class="preset-hero__thumb" />
            <div class="preset-hero__content">
                <Heading1>
                    {preset.pageTitle}
                </Heading1>
            </div>
        </Container>
    </section>

    <KonsolVergisiHesaplayiciPreset
        EXCHANGE_RATES={EXCHANGE_RATES}
        calculatorPage={konsolVergisiHesaplayiciPage}
        presetPage={konsolVergisiHesaplayiciPresetSlugPage}
        brand={brand}
        preset={preset}
        initial={initial}
        client:load />

    {presetsForCalculatorPresetCarousel.length > 0 &&
        <hr />
        <Container>
            <div class="ta-ad-first" ta-ad-container=""></div>

            <Heading2 tag="h2">
                Diğer hazır hesaplamalar
            </Heading2>
        </Container>
        <CalculatorPresetCarousel
            titleTag="h3"
            items={presetsForCalculatorPresetCarousel} />
    }

    <Container>
        <div class="ta-ad-last" ta-ad-container=""></div>
    </Container>
</AppLayout>

<style lang="scss" is:global>
    .preset-hero {
        margin-block-end: calc(var(--vh-spacer) * 2);
        .container {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: calc(var(--vh-spacer) * 1.5);
            @include vh-media-breakpoint-up(md) {
                flex-direction: row;
                gap: calc(var(--vh-spacer) * 2)
            }
        }
        &__thumb {
            flex-shrink: 0;
            inline-size: auto;
            block-size: calc(var(--vh-spacer) * 8);
            @include vh-media-breakpoint-up(md) {
                block-size: calc(var(--vh-spacer) * 10)
            }
        }
        &__content {
            .heading-1 {
                padding-block-end: 0
            }
        }
    }
</style>
