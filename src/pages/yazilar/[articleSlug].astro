---
import type { Yazi } from "@/domains/yazilar/types.js";
import AppLayout from "@/layouts/app-layout.astro";
import PageHeader from "@/components/common/page-header.vue";
import Container from "@/components/common/container.vue";
import Breadcrumbs from "@/components/common/breadcrumbs.vue";
import Heading1 from "@/components/common/heading-1.vue";
import ArticleLegalDisclaimerAlert from "@/components/article-legal-disclaimer-alert.vue";
import RichText from "@/components/common/rich-text.vue";
import Heading2 from "@/components/common/heading-2.vue";
import ArticlesGrid from "@/components/articles-grid.vue";
import SvgIcon from "@/components/common/svg-icon.vue";

import { icon_calendar, icon_refresh, icon_time } from "@/utils/icons.js";
import { render } from "astro:content";
import { YazilarPageDef, YazilarSlugPageDef } from "@/domains/yazilar/page-def.js";
import { getYazilar, getRelatedYazilar } from "@/domains/yazilar/db.js";
import {
    calculateReadingTimeInMinutes,
    getWordCount,
    parseDate,
    parseTitleAsTaxInfo
} from "@/domains/yazilar/utils.js";

export const getStaticPaths = async (): Promise<object> => {
    return (await getYazilar()).map(_yazi => ({
        params: {
            articleSlug: _yazi.slug
        },
        props: {
            yazi: _yazi
        }
    }));
};

type Props = {
    yazi: Yazi;
};
const { yazi } = Astro.props;

const yazilarPage = YazilarPageDef();
const yazilarSlugPage = YazilarSlugPageDef({ yazi });

const yazilar = await getYazilar();
const otherYazilar = getRelatedYazilar(yazi, yazilar, 6);

const createdDate = parseDate(yazi.createdDate);
const updatedDate = yazi.updatedDate ? parseDate(yazi.updatedDate) : null;
const taxInfo = parseTitleAsTaxInfo(yazi.title);
const wordCount = getWordCount(yazi.entry.body || "");
const readingTime = calculateReadingTimeInMinutes(wordCount);

const { Content } = await render(yazi.entry);
---

<AppLayout page={yazilarSlugPage}>
    <PageHeader>
        <Container>
            <Breadcrumbs
                items={yazilarSlugPage.breadcrumbs}
                client:load />
            <Heading1>
                {yazi.title}
            </Heading1>
        </Container>
    </PageHeader>

    <Container>
        <div class="ta-ad-first" ta-ad-container=""></div>

        <div class="meta">
            <span class="meta-item">
                <span class="meta-item-icon">
                    <SvgIcon icon={icon_calendar} />
                </span>
                <span class="meta-item-content">
                    <span class="meta-item-label">Yayınlanma</span>
                    <time class="meta-item-value" datetime={createdDate.timeDateTimeAttr}>
                        {createdDate.readableDate}
                    </time>
                </span>
            </span>

            {updatedDate && (
                <span class="meta-separator" aria-hidden="true"></span>
                <span class="meta-item">
                    <span class="meta-item-icon">
                        <SvgIcon icon={icon_refresh} />
                    </span>
                    <span class="meta-item-content">
                        <span class="meta-item-label">Son güncelleme</span>
                        <time class="meta-item-value" datetime={updatedDate.timeDateTimeAttr}>
                            {updatedDate.readableDate}
                        </time>
                    </span>
                </span>
            )}

            <span class="meta-separator" aria-hidden="true"></span>

            <span class="meta-item">
                <span class="meta-item-icon">
                    <SvgIcon icon={icon_time} />
                </span>
                <span class="meta-item-content">
                    <span class="meta-item-label">Okuma süresi</span>
                    <span class="meta-item-value">Yaklaşık {readingTime} dk</span>
                </span>
            </span>
        </div>

        <RichText
            tag="section"
            class="content">
            {taxInfo &&
                <table>
                    <thead>
                    <tr>
                        <th colspan="2">Vergi türü bilgisi</th>
                    </tr>
                    </thead>
                    <tbody>
                    <tr>
                        <td>Vergi adı</td>
                        <td>{taxInfo.name}</td>
                    </tr>
                    <tr>
                        <td>Vergi kodu</td>
                        <td class="text-number">{taxInfo.code}</td>
                    </tr>
                    </tbody>
                </table>
                <br />
            }
            <Content />
        </RichText>

        <hr />
        <ArticleLegalDisclaimerAlert />

        <div class="ta-ad-last" ta-ad-container=""></div>
    </Container>

    {otherYazilar.length > 0 &&
        <hr />

        <Container>
            <section>
                <Heading2 tag="h2">
                    <a href={yazilarPage.url}>
                        İlginizi çekebilecek diğer yazılar
                    </a>
                </Heading2>
                <ArticlesGrid
                    titleTag="h3"
                    items={otherYazilar} />

                <div class="ta-ad-last" ta-ad-container=""></div>
            </section>
        </Container>
    }
</AppLayout>

<style lang="scss">
    .content {
        --line-height-p: var(--vh-lh-xl)
    }

    .meta {
        @include vh-card();
        --color-hsl: var(--vh-clr-white-hsl);
        --bg-alpha: .02;
        --border-alpha: .08;
        background-image: none;
        display: flex;
        flex-direction: row;
        gap: calc(var(--vh-spacer) * 1.5);
        margin-block-end: calc(var(--vh-spacer) * 1.5);
        padding: calc(var(--vh-spacer) * .75) var(--vh-spacer);
        overflow-x: auto;
        scrollbar-width: thin;
        @include vh-media-breakpoint-down(sm) {
            inline-size: calc(100% + (var(--container-padding-inline) * 2));
            margin-inline: calc(var(--container-padding-inline) * -1);
            border-inline: 0;
            --border-radius: 0
        }
        &-item {
            display: flex;
            align-items: center;
            gap: .75rem;
            font-size: var(--vh-fs-sm);
            white-space: nowrap;
            &-icon {
                display: flex;
                align-items: center;
                justify-content: center;
                block-size: calc(var(--vh-spacer) * 2.25);
                inline-size: calc(var(--vh-spacer) * 2.25);
                border-radius: var(--vh-br-normal);
                background-color: hsla(var(--vh-clr-primary-hsl), .08);
                color: hsl(var(--vh-clr-primary-hsl))
            }
            &-content {
                display: flex;
                flex-direction: column
            }
            &-label {
                font-size: var(--vh-fs-xs);
                text-transform: uppercase
            }
            &-value {
                font-weight: var(--vh-fw-bold)
            }
        }
        .meta-separator {
            flex-shrink: 0;
            inline-size: var(--vh-border-inline-size);
            background-color: hsla(var(--vh-clr-white-hsl), var(--vh-clr-border-alpha))
        }
    }
</style>

<script is:inline type="module">
    document.addEventListener("DOMContentLoaded", () => {
        const detailsList = document.querySelectorAll("details");
        if (detailsList.length === 0) return;

        const faqData = {
            "@context": "https://schema.org",
            "@type": "FAQPage",
            "mainEntity": []
        };

        for (const _details of detailsList) {
            const question = _details.querySelector("summary")?.textContent.trim();
            const answer = _details.querySelector("div")?.textContent.trim();
            if (question || !answer) {
                faqData.mainEntity.push({
                    "@type": "Question",
                    "name": question,
                    "acceptedAnswer": {
                        "@type": "Answer",
                        "text": answer
                    }
                });
            }
        }

        const script = document.createElement("script");
        script.type = "application/ld+json";
        script.textContent = JSON.stringify(faqData, null, 0);
        document.head.append(script);
    });
</script>
