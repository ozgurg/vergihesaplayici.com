---
import type { Page } from "@/types/page-def.js";
import interLatinNormalFontWoff2Url from "@fontsource-variable/inter/files/inter-latin-wght-normal.woff2?url";

export type Props = {
    page: Page
};
const { page } = Astro.props;
const { head } = page;

const MAX_TITLE_LENGTH = 60;

const SITE_NAME = "Vergi Hesaplayıcı";
const SITE_COLOR = "#111912"; // Calculated start color of `page-header`s linear-gradient
const SITE_URL = siteUrl();
const SITE_MANIFEST_JSON = staticUrl("/manifest.json");
const SITE_X_CREATOR = "@vergihesaplar";

const PAGE_TITLE =
    head.title.length > MAX_TITLE_LENGTH
        ? head.title.split(" - ")[0]
        : head.title;

const PAGE_META_DESCRIPTION = head.description;
const PAGE_URL = head.canonicalUrl;
const PAGE_OG_IMAGE = head.ogImageUrl ?? staticSiteUrl("/og/ana-sayfa.jpg");
const PAGE_SCHEMA = (() => {
    const breadcrumbs = {
        "@type": "BreadcrumbList",
        "@id": `${PAGE_URL.href}#breadcrumb`,
        itemListElement: page.breadcrumbs.map((item, index) => ({
            "@type": "ListItem",
            position: index + 1,
            name: item.title,
            item: item.url.href
        }))
    };

    const schema: unknown = page.head.schema;

    if (schema && breadcrumbs) {
        if (typeof schema === "object" && !Array.isArray(schema) && "@graph" in schema) {
            const graph = schema["@graph"];
            return {
                ...schema,
                "@graph": Array.isArray(graph) ? [...graph, breadcrumbs] : [breadcrumbs]
            };
        }
        return [schema, { "@context": "https://schema.org", ...breadcrumbs }];
    }

    if (breadcrumbs) {
        return { "@context": "https://schema.org", ...breadcrumbs };
    }

    return schema;
})();
---

<meta charset="UTF-8" />
<meta http-equiv="x-ua-compatible" content="ie=edge" />
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=5,viewport-fit=cover,interactive-widget=resizes-content" />
<title>{PAGE_TITLE}</title>

<link rel="preload" as="font" type="font/woff2" href={interLatinNormalFontWoff2Url} crossorigin="anonymous" />
<link rel="dns-prefetch" href="https://cdn.apitiny.net" />

<meta name="description" content={PAGE_META_DESCRIPTION} />

<meta name="format-detection" content="telephone=no" />
<meta name="robots" content="index, follow" />

<base href={SITE_URL.href} />
<link href={PAGE_URL.href} rel="canonical" />

<link rel="alternate" href={PAGE_URL.href} hreflang="x-default" />
<link rel="alternate" href={PAGE_URL.href} hreflang="tr" />

<meta name="theme-color" content={SITE_COLOR} />
<link rel="manifest" href={SITE_MANIFEST_JSON.href} />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content={SITE_X_CREATOR} />
<meta name="twitter:title" content={PAGE_TITLE} />
<meta name="twitter:description" content={PAGE_META_DESCRIPTION} />
<meta name="twitter:url" content={PAGE_URL.href} />
<meta name="twitter:image" content={PAGE_OG_IMAGE} />
<meta name="twitter:image:alt" content={PAGE_TITLE} />
<meta name="twitter:creator" content={SITE_X_CREATOR} />

<meta name="author" content={SITE_NAME} />
<meta property="og:title" content={PAGE_TITLE} />
<meta property="og:site_name" content={SITE_NAME} />
<meta property="og:description" content={PAGE_META_DESCRIPTION} />
<meta property="og:url" content={PAGE_URL.href} />
<meta property="og:type" content="website" />
<meta property="og:image" content={PAGE_OG_IMAGE} />
<meta property="og:locale" content="tr_TR" />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={PAGE_TITLE} />

<link rel="icon" type="image/png" href={staticUrl("/pwa/favicon-96x96.png")} sizes="96x96" />
<link rel="icon" type="image/svg+xml" href={staticUrl("/pwa/favicon.svg")} />
<link rel="shortcut icon" href={staticUrl("/pwa/favicon.ico")} />
<link rel="apple-touch-icon" sizes="180x180" href={staticUrl("/pwa/apple-touch-icon-180.png")} />

<link rel="sitemap" type="application/xml" title="Sitemap" href={staticUrl("/sitemap-index.xml")} />

<meta name="msapplication-navbutton-color" content={SITE_COLOR} />
<meta name="msapplication-tap-highlight" content="no" />
<meta name="msapplication-TileColor" content={SITE_COLOR} />

<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-title" content={PAGE_TITLE} />
<meta name="apple-mobile-web-app-status-bar-style" content="black" />

{import.meta.env.PROD && <script is:inline src="https://analytics.ahrefs.com/analytics.js" data-key="hgZsRnZKNf2I0PbluLfvbA" async="" defer=""></script>}

<script is:inline define:vars={{ SERVICE_WORKER_URL: staticSiteUrl("/sw.js", false) }}>
    if ("serviceWorker" in window.navigator) {
        window.addEventListener("load", () => {
            window.navigator.serviceWorker.register(SERVICE_WORKER_URL);
        });
    }
</script>

<script is:inline type="application/ld+json" set:html={JSON.stringify(PAGE_SCHEMA)}></script>

<script>
    if (import.meta.env.PROD) {
        import("@/integrations/firebase.js");
    }
</script>
